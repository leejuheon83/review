# ===========================================
# Firebase + Vercel 연동 환경변수
# ===========================================
# 1. 이 파일을 .env.local 로 복사: cp .env.example .env.local
# 2. Firebase Console에서 값 채우기
# 3. Vercel: Settings > Environment Variables 에 동일 변수 추가

# --- Firebase Web SDK (클라이언트, NEXT_PUBLIC_ 필수) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# --- Firebase Admin SDK (서버, 데이터 저장용) ---
# 방식 A: 개별 변수
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=

# 방식 B: 서비스 계정 JSON 전체 (방식 A 대신 사용)
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}
# FIREBASE_DATABASE_URL=  # 방식 B 사용 시에도 필수

# --- Google Sheets (2중 관리용 백업 저장소) ---
# Firebase와 동시에 저장. Firebase 실패 시 로드 폴백으로 사용
GOOGLE_SPREADSHEET_ID=
# 방식 A: 개별 변수
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
# 방식 B: 서비스 계정 JSON 전체
# GOOGLE_SERVICE_ACCOUNT_JSON={"client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}
# GOOGLE_SHEET_NAME=DBState  # 시트 탭 이름 (기본값: DBState)
